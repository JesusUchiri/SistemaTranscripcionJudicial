# Copiar a .env y rellenar valores. No subir .env a git.
# Ejemplo producción (Dokploy): dominios judiscribeapi.ecosdelseo.com / judiscribe.ecosdelseo.com

# --- Base de datos ---
DATABASE_URL=postgresql+asyncpg://usuario:password@host:5432/nombre_bd

# --- Redis ---
REDIS_URL=redis://default:password@host:6379/0

# --- Deepgram ---
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3

# --- Anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# --- Hugging Face ---
HF_TOKEN=

# --- JWT ---
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Audio ---
AUDIO_STORAGE_PATH=/app/audio_files
AUDIO_ENCRYPTION_KEY=
AUDIO_RETENTION_DAYS=30

# --- General ---
ENVIRONMENT=production
CORS_ORIGINS=https://judiscribe.ecosdelseo.com
BACKEND_URL=https://judiscribeapi.ecosdelseo.com
