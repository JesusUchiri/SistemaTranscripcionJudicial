# Copia este contenido a .env para desarrollo 100% local (Postgres y Redis en Docker).
# Luego:  docker compose -f docker-compose.local.yml up -d
#         alembic upgrade head
#         python -m uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload

DATABASE_URL=postgresql+asyncpg://judiscribe:judiscribe_secret@localhost:5432/judiscribe
REDIS_URL=redis://localhost:6379/0

DEEPGRAM_API_KEY=
ANTHROPIC_API_KEY=
HF_TOKEN=

JWT_SECRET_KEY=clave-local-cambiar-en-produccion
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

AUDIO_STORAGE_PATH=./audio_files
AUDIO_ENCRYPTION_KEY=
AUDIO_RETENTION_DAYS=30

ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000
